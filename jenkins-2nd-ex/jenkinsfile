pipeline {
    agent any

    triggers {
        pollSCM('H/1 * * * *')
    }

    stages {

        stage('Uptime') {
            steps {
                sh 'uptime'
            }
        }

        stage('RAM Usage') {
            steps {
                sh 'free -h'
            }
        }

        stage('Disk Usage') {
            steps {
                sh 'df -h'
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Poll SCM Check') {
            steps {
                sh '''
                echo "Checking whether Poll SCM works or not"
                '''
            }
        }

    }
}