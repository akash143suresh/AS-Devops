pipeline {
    agent any

    stages {

        stage('Uptime') {
            steps {
                sh 'uptime'
            }
        }

        stage('RAM Usage') {
            steps {
                sh 'free -h'
            }
        }

        stage('Disk Usage') {
            steps {
                sh 'df -h'
            }
        }
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('SCM Poll Test') {
            steps {
                sh '''
                echo "SCM Poll Triggered Successfully"
                date
                '''
    }
}