pipeline{
    agent any
    stages{
        stage('uptime'){
            steps{
                sh '''
                uptime
                '''
            }
        }
        storage ('Ram-Used'){
            steps{
                sh '''
                free -h
                '''
            }
        }
        stage('disk-usage'){
            steps{
                sh '''
                df -h
                '''
            }
        }
    }
}
